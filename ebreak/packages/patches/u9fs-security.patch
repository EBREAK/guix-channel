From b2a2c2d05570a1ad648f617cf5b9241d8c42259d Mon Sep 17 00:00:00 2001
From: t <t@t>
Date: Sun, 19 Jul 2026 19:42:52 +0800
Subject: [PATCH 1/2] Security hardening for serving untrusted 9P clients

- Reject 9P messages larger than the negotiated msize.  The
  client-declared message length was only lower-bound checked before
  readn() filled an msize-sized heap buffer, allowing a pre-auth heap
  overflow with client-controlled data.

- Contain paths to the export root with realpath.  u9fs follows
  symlinks, so a symlink inside the export root pointing at an
  absolute path was served outside the export.  rootpath() is the
  single choke point for all file system operations; paths whose
  realpath(3) (or their parent's, for not-yet-existing files) escapes
  the export root are redirected to a nonexistent name.

- Disable special-file access via aname="device".
---
 u9fs.c | 43 ++++++++++++++++++++++++++++++++++++++-----
 1 file changed, 38 insertions(+), 5 deletions(-)

diff --git a/u9fs.c b/u9fs.c
index ea0391c..e0591cc 100644
--- a/u9fs.c
+++ b/u9fs.c
@@ -183,6 +183,35 @@ char isfrog[256]={
 	/*'x'*/	0, 0, 0, 0, 0, 0, 0, 1,	/*DEL*/
 };
 
+static int pathescapes(char *path);
+
+static int
+pathescapes(char *path)
+{
+	static char rroot[PATH_MAX];
+	char resolved[PATH_MAX], parent[PATH_MAX], *slash;
+	int n;
+
+	if(realpath(root, rroot) == nil)
+		return 0;
+	if(strcmp(rroot, "/") == 0)
+		return 0;	/* exporting /: nothing to contain */
+	n = strlen(rroot);
+	if(realpath(path, resolved) == nil){
+		/* Path does not exist (e.g. create target); check its parent. */
+		snprint(parent, sizeof parent, "%s", path);
+		slash = strrchr(parent, '/');
+		if(slash == nil || slash == parent)
+			strcpy(parent, "/");
+		else
+			*slash = '\0';
+		if(realpath(parent, resolved) == nil)
+			return 0;	/* the syscall will fail anyway */
+	}
+	return strncmp(resolved, rroot, n) != 0
+	    || (resolved[n] != '\0' && resolved[n] != '/');
+}
+
 char*
 rootpath(char *path)
 {
@@ -191,6 +220,10 @@ rootpath(char *path)
 	if(root == nil)
 		return path;
 	snprint(buf, sizeof buf, "%s%s", root, path);
+	if(pathescapes(buf)){
+		errno = EACCES;
+		snprint(buf, sizeof buf, "%s/.u9fs-denied-nonexistent", root);
+	}
 	return buf;
 }
 
@@ -208,6 +241,8 @@ getfcallnew(int fd, Fcall *fc, int have)
 	len = GBIT32(rxbuf);
 	if(len <= BIT32SZ)
 		sysfatal("bogus message");
+	if(len > msize)
+		sysfatal("message too large");
 
 	len -= BIT32SZ;
 	if(readn(fd, rxbuf+BIT32SZ, len) != len)
@@ -407,11 +442,9 @@ rattach(Fcall *rx, Fcall *tx)
 		rx->aname = "";
 
 	if(strcmp(rx->aname, "device") == 0){
-		if(connected && !devallowed){
-			seterror(tx, Especial0);
-			return;
-		}
-		devallowed = 1;
+		/* aname="device" special-file access disabled */
+		seterror(tx, Especial0);
+		return;
 	}else{
 		if(connected && devallowed){
 			seterror(tx, Especial1);
-- 
